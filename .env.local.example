# Public site URL (canonical, sitemap, OG). TODO: real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Airbnb iCal export URL. Absent = mock availability (demo mode).
# TODO: get from owner (Airbnb host calendar > Availability > Connect another website)
AIRBNB_ICAL_URL=

# Tier 1: Resend. TODO: API key + verified sending domain.
RESEND_API_KEY=
INQUIRY_TO_EMAIL=
INQUIRY_FROM_EMAIL=

# Tier 2: Web3Forms fallback. TODO: access key (free, web3forms.com)
WEB3FORMS_ACCESS_KEY=

# Optional distributed rate limiting (recommended for production).
# Without these, an in-memory per-instance fallback is used (best effort).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
